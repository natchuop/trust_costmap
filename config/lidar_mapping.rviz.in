Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Occupancy1
        - /LiDAR Scans1
        - /Navigation1
      Splitter Ratio: 0.55
    Tree Height: 720
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded: []
    Name: Tool Properties
    Splitter Ratio: 0.588679
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.25
      Cell Size: 0.5
      Class: rviz_default_plugins/Grid
      Color: 110; 110; 110
      Enabled: true
      Line Style:
        Line Width: 0.02
        Value: Lines
      Name: Reference Grid
      Normal Cell Count: 80
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 80
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz_common/Group
      Displays:
        - Alpha: 0.85
          Class: rviz_default_plugins/GridCells
          Color: 80; 190; 255
          Enabled: true
          Name: Static Free Floor
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /rviz_base_free
          Value: true
        - Alpha: 1
          Class: rviz_default_plugins/GridCells
          Color: 90; 40; 140
          Enabled: true
          Name: Static Walls
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /rviz_base_occupied
          Value: true
        - Alpha: 0.70
          Class: rviz_default_plugins/GridCells
          Color: 40; 230; 255
          Enabled: true
          Name: LiDAR Free (Combined)
          Topic:
            Depth: 2
            Durability Policy: Transient Local
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /__ROBOT_ID__/lidar_free_cells
          Value: true
        - Alpha: 1
          Class: rviz_default_plugins/GridCells
          Color: 255; 70; 90
          Enabled: true
          Name: LiDAR Occupied (Combined)
          Topic:
            Depth: 2
            Durability Policy: Transient Local
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /__ROBOT_ID__/lidar_occupied_cells
          Value: true
        - Class: rviz_default_plugins/MarkerArray
          Enabled: true
          Name: Robot Footprint Square
          Namespaces:
            turtlebot_footprint: true
            turtlebot_heading: true
            turtlebot_label: true
          Topic:
            Depth: 2
            Durability Policy: Transient Local
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /__ROBOT_ID__/footprint_markers
          Value: true
      Enabled: true
      Name: Occupancy
    - Class: rviz_common/Group
      Displays:
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz_default_plugins/LaserScan
          Color: 255; 90; 40
          Color Transformer: FlatColor
          Decay Time: 0.30
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 4096
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: Selected Robot Scan
          Position Transformer: XYZ
          Selectable: true
          Size (Pixels): 5
          Size (m): 0.045
          Style: FlatSquares
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /__ROBOT_ID__/scan_rviz
          Use Fixed Frame: true
          Use rainbow: false
          Value: true
__PEER_SCAN_DISPLAYS__
      Enabled: true
      Name: LiDAR Scans
    - Class: rviz_common/Group
      Displays:
        - Alpha: 1
          Buffer Length: 1
          Class: rviz_default_plugins/Path
          Color: 25; 255; 80
          Enabled: true
          Head Diameter: 0.18
          Head Length: 0.12
          Length: 0.3
          Line Style: Lines
          Line Width: 0.06
          Name: Selected Robot Route
          Offset:
            X: 0
            Y: 0
            Z: 0.12
          Pose Color: 255; 85; 255
          Pose Style: None
          Radius: 0.03
          Shaft Diameter: 0.08
          Shaft Length: 0.16
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /agent_routes/__ROBOT_ID__
          Value: true
        - Class: rviz_default_plugins/MarkerArray
          Enabled: true
          Name: Action Goals
          Namespaces:
            action_goals: true
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /action_goal_markers
          Value: true
      Enabled: true
      Name: Navigation
  Enabled: true
  Global Options:
    Background Color: 42; 42; 42
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /clicked_point
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Angle: 0
      Class: rviz_default_plugins/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Scale: 45
      Target Frame: map
      Value: TopDownOrtho (rviz)
      X: 8
      Y: 8
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Selection:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: false
  Width: 1440
  X: 80
  Y: 40
